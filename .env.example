# SMS transport: "adb" for Android Debug Bridge, "at" for a USB GSM modem,
# "mock" for local testing.
SMS_BACKEND=mock
SMS_SERIAL_PORT=/dev/ttyUSB0
SMS_BAUDRATE=115200
SMS_POLL_SECONDS=5
SMS_MESSAGE_STATUS=REC UNREAD
# Optional: SM for SIM storage, ME for phone storage.
SMS_STORAGE=

# Android/ADB SMS backend.
ADB_PATH=adb
ADB_SERIAL=
# compose opens the SMS app with the reply filled in, log only logs replies,
# template runs ADB_SEND_COMMAND_TEMPLATE for silent/helper-app sending.
ADB_SEND_MODE=compose
# Optional command template for silent SMS sending. Use {adb}, {serial_args},
# {phone}, and {body}. Without this, the ADB backend can read SMS but not send.
ADB_SEND_COMMAND_TEMPLATE=
# Tracks the last processed Android SMS _id so opened/read messages are still
# processed when they are newer than the high-water mark.
ADB_STATE_FILE=./adb-sms-state.txt
# On first run, skip older messages already in the inbox.
ADB_SKIP_EXISTING=true

# Chat session backend: "kubernetes" creates pods, "local" is for development.
SESSION_BACKEND=local

# Kubernetes session pods. Used when SESSION_BACKEND=kubernetes.
KUBERNETES_NAMESPACE=default
CHAT_POD_IMAGE=sms-chatgpt:latest
CHAT_POD_IDLE_SECONDS=60
CHAT_POD_TIMEOUT_SECONDS=30

# LLM provider.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Mock mode files.
MOCK_INBOX_FILE=./mock-inbox.txt
MOCK_OUTBOX_FILE=./mock-outbox.txt
